---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";
import { APP_DESCRIPTION, APP_NAME } from "../lib/app";
---

<AppShell title={`${APP_NAME} · Ansiversa`} description={APP_DESCRIPTION}>
  <section class="py-24">
    <AvContainer size="narrow">
      <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-10 md:p-14">
        <p class="text-xs tracking-[0.25em] text-cyan-300 uppercase">Ansiversa premium mini app</p>
        <h1 class="mt-4 text-4xl md:text-6xl font-semibold leading-tight">Build elegant itineraries for every trip.</h1>
        <p class="mt-6 text-slate-300 text-lg">
          Design day-by-day travel plans, keep activities organized, and archive every completed journey without losing your history.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <AvButton href="/app">Open workspace</AvButton>
          <AvButton href="#features" variant="outline">See features</AvButton>
        </div>
      </div>
    </AvContainer>
  </section>

  <section id="features" class="pb-20">
    <AvContainer>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          "Plan complete trips with clean details and status tracking.",
          "Shape each day with custom notes and structured activities.",
          "Sync summary insights back to your parent Ansiversa dashboard.",
        ].map((copy) => (
          <article class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 text-slate-300">{copy}</article>
        ))}
      </div>
    </AvContainer>
  </section>
</AppShell>
