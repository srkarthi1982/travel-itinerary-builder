---
import { actions } from "astro:actions";
import { AvButton } from "@ansiversa/components";
import AppWorkspace from "../../../layouts/AppWorkspace.astro";

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/app");
}

let detail;
try {
  const response = await Astro.callAction(actions.getTripDetail, { id });
  detail = response.data;
} catch {
  return Astro.redirect("/app");
}

if (!detail) {
  return Astro.redirect("/app");
}

const { trip, days, activitiesByDay } = detail;
const totalActivities = activitiesByDay.reduce((acc, group) => acc + group.activities.length, 0);
---

<AppWorkspace title={`${trip.title} · Trip details`} description={`Itinerary for ${trip.destination}`}>
  <section x-data="{ openDay:false, dayId:'' }" class="space-y-6">
    <a href="/app" class="text-sm text-slate-400 hover:text-cyan-300">← Back to trips</a>
    <header class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
      <div class="flex flex-wrap justify-between gap-4">
        <div>
          <h1 class="text-3xl font-semibold">{trip.title}</h1>
          <p class="text-slate-400 mt-1">{trip.destination} · {trip.startDate.toLocaleDateString()} – {trip.endDate.toLocaleDateString()}</p>
          <p class="text-slate-300 mt-4">{trip.notes || "No trip notes yet."}</p>
        </div>
        <div class="flex gap-2 items-start">
          <span class="px-3 py-1 rounded-full text-xs border border-slate-700 uppercase tracking-wide">{trip.status}</span>
          <form method="POST" action={actions.updateTrip}>
            <input type="hidden" name="id" value={trip.id} />
            <input type="hidden" name="status" value="completed" />
            <button class="px-3 py-2 rounded-lg border border-slate-700 text-sm">Mark completed</button>
          </form>
        </div>
      </div>
      <div class="mt-6 grid sm:grid-cols-2 gap-3 text-sm">
        <div class="rounded-xl border border-slate-800 p-3">Total days: <strong>{days.length}</strong></div>
        <div class="rounded-xl border border-slate-800 p-3">Total activities: <strong>{totalActivities}</strong></div>
      </div>
    </header>

    <div class="flex justify-end">
      <AvButton type="button" @click="openDay=true">Add day</AvButton>
    </div>

    <div class="space-y-4">
      {days.length === 0 ? (
        <p class="rounded-2xl border border-dashed border-slate-700 p-8 text-center text-slate-400">No days yet. Add day 1 to start your itinerary.</p>
      ) : (
        days.map((day) => {
          const activities = activitiesByDay.find((entry) => entry.dayId === day.id)?.activities ?? [];
          return (
            <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 space-y-4">
              <div class="flex flex-wrap justify-between gap-3">
                <div>
                  <h2 class="text-xl font-semibold">Day {day.dayNumber}{day.title ? ` · ${day.title}` : ""}</h2>
                  <p class="text-slate-400">{day.date ? day.date.toLocaleDateString() : "No date set"}</p>
                  {day.notes && <p class="text-slate-300 mt-2">{day.notes}</p>}
                </div>
                <div class="flex gap-2 items-start">
                  <button type="button" @click={`dayId='${day.id}'; openDay=false`} class="px-3 py-2 rounded-lg border border-slate-700 text-sm">Add activity below</button>
                  <form method="POST" action={actions.deleteTripDay}>
                    <input type="hidden" name="id" value={day.id} />
                    <button class="px-3 py-2 rounded-lg border border-rose-700 text-rose-300 text-sm">Delete day</button>
                  </form>
                </div>
              </div>

              <div class="space-y-3 border-l-2 border-slate-700 pl-4">
                {activities.length === 0 ? (
                  <p class="text-slate-500 text-sm">No activities yet.</p>
                ) : (
                  activities.map((activity) => (
                    <div class="rounded-xl border border-slate-800 bg-slate-950/60 p-4">
                      <div class="flex flex-wrap justify-between gap-2">
                        <div>
                          <p class="font-medium">{activity.title}</p>
                          <p class="text-sm text-slate-400">{activity.category || "activity"}{activity.location ? ` · ${activity.location}` : ""}</p>
                        </div>
                        <form method="POST" action={actions.deleteTripActivity}>
                          <input type="hidden" name="id" value={activity.id} />
                          <button class="text-sm text-rose-300">Delete</button>
                        </form>
                      </div>
                      {(activity.startTime || activity.endTime) && (
                        <p class="text-xs text-slate-400 mt-2">{activity.startTime || "--"} – {activity.endTime || "--"}</p>
                      )}
                      {activity.description && <p class="text-sm text-slate-300 mt-2">{activity.description}</p>}
                    </div>
                  ))
                )}

                <form method="POST" action={actions.createTripActivity} class="rounded-xl border border-slate-800 p-4 grid md:grid-cols-6 gap-2">
                  <input type="hidden" name="tripDayId" value={day.id} />
                  <input name="title" required placeholder="Add activity" class="md:col-span-2 rounded-lg bg-slate-800 border border-slate-700 p-2 text-sm" />
                  <input name="location" placeholder="Location" class="rounded-lg bg-slate-800 border border-slate-700 p-2 text-sm" />
                  <input name="startTime" type="time" class="rounded-lg bg-slate-800 border border-slate-700 p-2 text-sm" />
                  <input name="endTime" type="time" class="rounded-lg bg-slate-800 border border-slate-700 p-2 text-sm" />
                  <input name="category" placeholder="Category" class="rounded-lg bg-slate-800 border border-slate-700 p-2 text-sm" />
                  <textarea name="description" placeholder="Description" class="md:col-span-5 rounded-lg bg-slate-800 border border-slate-700 p-2 text-sm"></textarea>
                  <button class="rounded-lg bg-cyan-500 text-slate-950 text-sm font-medium px-3">Save</button>
                </form>
              </div>
            </article>
          );
        })
      )}
    </div>

    <div x-show="openDay" x-cloak class="fixed inset-0 bg-slate-950/80 p-4 md:p-12 z-30 overflow-auto">
      <div class="max-w-xl mx-auto rounded-2xl border border-slate-800 bg-slate-900 p-6">
        <div class="flex items-center justify-between mb-4"><h2 class="text-xl font-semibold">Add day</h2><button @click="openDay=false">✕</button></div>
        <form method="POST" action={actions.createTripDay} class="space-y-3">
          <input type="hidden" name="tripId" value={trip.id} />
          <input name="dayNumber" type="number" min="1" value={days.length + 1} required class="w-full rounded-lg bg-slate-800 border border-slate-700 p-3" />
          <input name="date" type="date" class="w-full rounded-lg bg-slate-800 border border-slate-700 p-3" />
          <input name="title" placeholder="Day title (optional)" class="w-full rounded-lg bg-slate-800 border border-slate-700 p-3" />
          <textarea name="notes" placeholder="Day notes" class="w-full rounded-lg bg-slate-800 border border-slate-700 p-3"></textarea>
          <div class="flex justify-end gap-2">
            <button type="button" @click="openDay=false" class="px-3 py-2 rounded-lg border border-slate-700">Cancel</button>
            <button class="px-4 py-2 rounded-lg bg-cyan-500 text-slate-950 font-medium">Add day</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</AppWorkspace>
