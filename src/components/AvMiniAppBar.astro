---
import { AvButton, AvContainer } from "@ansiversa/components";
import { APP_ID, APP_LOGO_KEY, APP_NAME } from "../lib/app";

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-800 bg-slate-950/90 backdrop-blur">
  <AvContainer>
    <div class="flex items-center justify-between py-4 gap-4">
      <a href="/app" class="flex items-center gap-3 text-slate-100 font-semibold">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 text-white">
          ✈️
        </span>
        <span>{APP_NAME}</span>
      </a>
      <div class="flex items-center gap-2 text-sm">
        <span class="hidden sm:inline text-slate-400">{APP_ID}:{APP_LOGO_KEY}</span>
        {currentPath === "/app" ? (
          <AvButton href="/" variant="secondary">Public Page</AvButton>
        ) : (
          <AvButton href="/app" variant="secondary">Workspace</AvButton>
        )}
      </div>
    </div>
  </AvContainer>
</header>
